# 环境变量配置

# OpenAI API Key（必填）
OPENAI_API_KEY=sk-your-api-key-here

# 可选：组织 ID
# OPENAI_ORG_ID=org-your-org-id

# 可选：项目 ID
# OPENAI_PROJECT_ID=proj-your-project-id

# 可选：自定义 API 地址（用于代理或兼容接口）
# OPENAI_BASE_URL=https://api.your-proxy.com/v1

# 可选：运行环境
ENVIRONMENT=development

# 可选：日志级别
LOG_LEVEL=INFO
